{
  "name": "@devheerim/figma-mcp",
  "version": "1.0.6",
  "description": "Enhanced Figma MCP Server with prototype flow analysis — exposes screen lists, prototype connections, and full flow maps via Figma REST API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "figma-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "figma",
    "mcp",
    "model-context-protocol",
    "prototype",
    "design",
    "claude"
  ],
  "author": "devheerim",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devheerim/figma-mcp.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
